---
import { getImagesFromFolders } from "../utils/readImages";
import { cn } from "../utils/cn";

const { section } = Astro.props;
const images = getImagesFromFolders("/public/" + section?.folderPath);
const galleryGridId = `gallery-grid-${String(
  section?.id || section?.folderPath || "default"
).replace(/[^a-zA-Z0-9_-]/g, "-")}`;
const parseVisibleCount = (value: unknown, fallback: number) => {
  const parsed = Number(value);
  if (!Number.isFinite(parsed) || parsed < 1) return fallback;
  return Math.floor(parsed);
};
const initialVisibleMobile = parseVisibleCount(
  section?.initialVisibleMobile,
  4
);
const initialVisibleDesktop = parseVisibleCount(
  section?.initialVisibleDesktop,
  8
);
---

<style is:global>
  .gallery-grid:not(.gallery-expanded) .gallery-item.gallery-mobile-hidden {
    display: none;
  }

  @media (min-width: 1024px) {
    .gallery-grid:not(.gallery-expanded) .gallery-item.gallery-mobile-hidden {
      display: list-item;
    }

    .gallery-grid:not(.gallery-expanded) .gallery-item.gallery-desktop-hidden {
      display: none;
    }
  }

  .gallery-grid.gallery-expanded .gallery-item {
    display: list-item;
  }
</style>

<script>
  if (!window.__galleryExpandInit) {
    window.__galleryExpandInit = true;

  const parseLimit = (value, fallback) => {
    const parsed = Number(value);
    if (!Number.isFinite(parsed) || parsed < 1) return fallback;
    return Math.floor(parsed);
  };

  const updateGalleryButtons = () => {
    const grids = document.querySelectorAll("[data-gallery-grid]");
    const isDesktop = window.matchMedia("(min-width: 1024px)").matches;

    grids.forEach((grid) => {
      const targetId = grid.getAttribute("id");
      if (!targetId) return;

      const button = document.querySelector(
        `.gallery-expand-btn[data-gallery-target="${targetId}"]`
      );
      if (!button) return;

      if (grid.classList.contains("gallery-expanded")) {
        button.remove();
        return;
      }

      const mobileLimit = parseLimit(
        grid.getAttribute("data-visible-mobile"),
        4
      );
      const desktopLimit = parseLimit(
        grid.getAttribute("data-visible-desktop"),
        8
      );
      const visibleLimit = isDesktop ? desktopLimit : mobileLimit;
      const totalItems = grid.querySelectorAll(".gallery-item").length;

      button.style.display = totalItems > visibleLimit ? "" : "none";
    });
  };

  document.addEventListener("click", (event) => {
    const button = event.target instanceof Element
      ? event.target.closest(".gallery-expand-btn")
      : null;
    if (!button) return;

    const gridId = button.getAttribute("data-gallery-target");
    if (!gridId) return;

    const grid = document.getElementById(gridId);
    if (!grid) return;

    grid.classList.add("gallery-expanded");
    button.remove();
  });

  document.addEventListener("DOMContentLoaded", updateGalleryButtons);
  window.addEventListener("resize", updateGalleryButtons);
  }
</script>

<section
  id={`${section?.id || ""}`}
  class={cn(section?.noMarginTop ? "pt-0" : "pt-16 sm:pt-24 md:pt-32")}
>
  {
    section?.mode === 1 && (
      <div style={`background-color:${section?.bgColor}`}>
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-2xl">
            <h2 class="text-3xl font-bold  text-gray-900 sm:text-4xl text-center">
              {section?.title?.map((line: string, index: number) => (
                <Fragment key={index}>
                  <span class="block leading-16">{line}</span>
                </Fragment>
              ))}
            </h2>

            {section?.description?.map((info: string, index: number) => (
              <Fragment key={index}>
                <p class="mt-4 text-lg leading-8 text-gray-600 text-center">
                  {info}
                </p>
              </Fragment>
            ))}
          </div>

          <div class="mx-auto mt-16 grid max-w-2xl auto-rows-fr grid-cols-1 gap-16 sm:mt-20 lg:mx-0 lg:max-w-none text-center">
            {images?.map((item, index) => (
              <Fragment key={index}>
                <div>
                  <div class="relative isolate flex flex-col justify-end overflow-hidden rounded-2xl bg-gray-900">
                    <img
                      src={item?.src?.replace("/public", "")}
                      alt={item?.name}
                      class="w-full object-contain cursor-pointer"
                      loading="lazy"
                      data-src={item?.src}
                      tabindex="0"
                    />
                  </div>
                  {section?.showImgName ? (
                    <div
                      class="mt-3 text-lg leading-6 text-shadow-all shadow-gray-100"
                      style={`color: ${section?.imgNameColor}`}
                    >
                      <span class="text-center">
                        <span class="absolute inset-0" />
                        {item?.name.split("__").map((part, subIndex) => (
                          <Fragment key={subIndex}>
                            {part
                              ?.replace(/_/g, " ")
                              ?.replace(/w:/g, "w/")
                              ?.replace(/w:o/g, "w/o")}
                            <br />
                            <br />
                          </Fragment>
                        ))}
                      </span>
                    </div>
                  ) : (
                    ""
                  )}
                </div>
              </Fragment>
            ))}
          </div>
        </div>
      </div>
    )
  }

  {
    section?.mode === 2 && (
      <div style={`background-color:${section?.bgColor}`}>
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-2xl">
            <h2 class="text-3xl font-bold  text-gray-900 sm:text-4xl text-center">
              {section?.title?.map((line: string, index: number) => (
                <Fragment key={index}>
                  <span class="block leading-16">{line}</span>
                </Fragment>
              ))}
            </h2>

            {section?.description?.map((info: string, index: number) => (
              <Fragment key={index}>
                <p class="mt-4 text-lg leading-8 text-gray-600 text-center">
                  {info}
                </p>
              </Fragment>
            ))}
          </div>
          <div class="mx-auto mt-16 grid max-w-2xl auto-rows-fr grid-cols-1 sm:grid-cols-2 gap-16 sm:mt-20 lg:mx-0 lg:max-w-none text-center">
            {images?.map((item, index) => (
              <Fragment key={index}>
                <div>
                  <div class="relative isolate flex flex-col justify-end overflow-hidden rounded-2xl bg-gray-900">
                    <img
                      src={item?.src?.replace("/public", "")}
                      alt={item?.name}
                      class="w-full object-contain cursor-pointer"
                      loading="lazy"
                      data-src={item?.src}
                      tabindex="0"
                    />
                  </div>
                  {section?.showImgName ? (
                    <div
                      class="mt-3 text-lg leading-6 text-shadow-all shadow-gray-100"
                      style={`color: ${section?.imgNameColor}`}
                    >
                      <span class="text-center">
                        <span class="absolute inset-0" />
                        {item?.name.split("__").map((part, subIndex) => (
                          <Fragment key={subIndex}>
                            {part
                              ?.replace(/_/g, " ")
                              ?.replace(/w:/g, "w/")
                              ?.replace(/w:o/g, "w/o")}
                            <br />
                            <br />
                          </Fragment>
                        ))}
                      </span>
                    </div>
                  ) : (
                    ""
                  )}
                </div>
              </Fragment>
            ))}
          </div>
        </div>
      </div>
    )
  }
  {
    section?.mode === 3 && (
      <div style={`background-color:${section?.bgColor}`}>
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="flex flex-col justify-center items-center mx-auto max-w-2xl">
            <h2 class="text-3xl font-bold  text-gray-900 sm:text-4xl text-center">
              {section?.title?.map((line: string, index: number) => (
                <Fragment key={index}>
                  <span class="block leading-16">{line}</span>
                </Fragment>
              ))}
            </h2>

            {section?.description?.map((info: string, index: number) => (
              <Fragment key={index}>
                <p class="mt-4 text-lg leading-8 text-gray-600 text-center">
                  {info}
                </p>
              </Fragment>
            ))}
          </div>
          <ul
            role="list"
            class="mx-auto mt-8 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-14 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3 xl:grid-cols-3"
          >
            {images?.map((item, index) => (
              <Fragment key={index}>
                <li>
                  <img
                    src={item?.src?.replace("/public", "")}
                    alt={item?.name}
                    class={`aspect-[14/13] w-full rounded-2xl object-cover rounded-${section?.menuItemImgRounded} hover:scale-105 duration-300 object-contain cursor-pointer`}
                    loading="lazy"
                    data-src={item?.src}
                    tabindex="0"
                  />
                  {section?.showImgName ? (
                    <div
                      class="mt-6 text-lg leading-8  text-center"
                      style={`color: ${section?.imgNameColor}`}
                    >
                      {item?.name.split("__").map((part) => (
                        <span>
                          {part
                            ?.replace(/_/g, " ")
                            ?.replace(/w:/g, "w/")
                            ?.replace(/w:o/g, "w/o")}
                          <br />
                        </span>
                      ))}
                    </div>
                  ) : (
                    ""
                  )}
                </li>
              </Fragment>
            ))}
          </ul>
        </div>
      </div>
    )
  }

  {
    section?.mode === 4 && (
      <div style={`background-color:${section?.bgColor}`}>
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="flex flex-col justify-center items-center mx-auto max-w-2xl">
            <h2 class="text-3xl font-bold  text-gray-900 sm:text-4xl text-center">
              {section?.title?.map((line: string, index: number) => (
                <Fragment key={index}>
                  <span class="block leading-16">{line}</span>
                </Fragment>
              ))}
            </h2>

            {section?.description?.map((info: string, index: number) => (
              <Fragment key={index}>
                <p class="mt-4 text-lg leading-8 text-gray-600 text-center">
                  {info}
                </p>
              </Fragment>
            ))}
          </div>
          <ul
            role="list"
            id={galleryGridId}
            data-gallery-grid
            data-visible-mobile={initialVisibleMobile}
            data-visible-desktop={initialVisibleDesktop}
            class="gallery-grid mx-auto mt-8 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-14 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3 xl:grid-cols-4"
          >
            {images?.map((item, index) => (
              <Fragment key={index}>
                <li
                  class={cn(
                    "gallery-item",
                    index + 1 > initialVisibleMobile ? "gallery-mobile-hidden" : "",
                    index + 1 > initialVisibleDesktop ? "gallery-desktop-hidden" : ""
                  )}
                  data-index={index}
                >
                  <img
                    src={item?.src?.replace("/public", "")}
                    alt={item?.name}
                    class={`aspect-[14/13] w-full rounded-2xl object-cover rounded-${section?.menuItemImgRounded} hover:scale-105 duration-300 object-contain cursor-pointer`}
                    loading="lazy"
                    data-src={item?.src}
                    tabindex="0"
                  />
                  {section?.showImgName ? (
                    <div
                      class="mt-6 text-lg leading-8  text-center"
                      style={`color: ${section?.imgNameColor}`}
                    >
                      {item?.name.split("__").map((part) => (
                        <span>
                          {part
                            ?.replace(/_/g, " ")
                            ?.replace(/w:/g, "w/")
                            ?.replace(/w:o/g, "w/o")}
                          <br />
                        </span>
                      ))}
                    </div>
                  ) : (
                    ""
                  )}
                </li>
              </Fragment>
            ))}
          </ul>

          {images?.length > Math.min(initialVisibleMobile, initialVisibleDesktop) && (
            <div class="flex justify-center mt-12">
              <button
                type="button"
                class="gallery-expand-btn px-8 py-3 bg-gray-900 text-white font-semibold rounded-lg hover:bg-gray-800 transition-colors"
                data-gallery-target={galleryGridId}
              >
                View More
              </button>
            </div>
          )}
        </div>
      </div>
    )
  }
</section>
